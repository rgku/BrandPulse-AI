generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  password      String
  plan          String    @default("free")
  stripeId      String?
  trialEnds     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  brands        Brand[]
  reports       Report[]
}

model Brand {
  id          String    @id @default(uuid())
  name        String
  website     String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitors    Monitor[]
  createdAt   DateTime  @default(now())
}

model Monitor {
  id          String    @id @default(uuid())
  brandId     String
  brand       Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  engine      String
  visibility  Int
  response    String
  sentiment   String
  checkedAt   DateTime  @default(now())
}

model Report {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  data        Json
  sentAt      DateTime  @default(now())
}
